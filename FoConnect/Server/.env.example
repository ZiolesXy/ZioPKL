ENV=development
APP_NAME=ChatApp
SERVER_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=chatapp_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=super_secret_jwt_key_change_in_production_12345
JWT_EXPIRE_IN_HOURS=24

# End-to-End Encryption
E2EE_MASTER_KEY=master_encryption_key_for_secrets

# Cloudinary
CLOUDINARY_URL=cloudinary://user:key@host
CLOUDINARY_UPLOAD_PRESET=preset_name

# Google Cloud / FCM
FCM_SERVER_KEY=your_fcm_server_key_here
PROJECT_ID=your_project_id

# Translation
DEEPL_API_KEY=your_deepl_api_key
GOOGLE_TRANSLATE_API_KEY=your_google_translate_key

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://app.chatapp.com